    "#| label: setup-embi\n",
    "#| echo: false\n",
    "#| warning: false\n",
    "\n",
    "\n",
    "\n",
    "import pandas as pd\n",
    "import plotly.graph_objects as go\n",
    "import plotly.express as px\n",
    "from IPython.display import Markdown, display\n",
    "\n",
    "url_embi_xls = \"https://bcrdgdcprod.blob.core.windows.net/documents/entorno-internacional/documents/Serie_Historica_Spread_del_EMBI.xlsx\"\n",
    "\n",
    "try:\n",
    "    df_embi = pd.read_excel(\n",
    "        url_embi_xls,\n",
    "        sheet_name=0,\n",
    "        header=1,\n",
    "        index_col=None\n",
    "    )\n",
    "\n",
    "    # Eliminar columnas Unnamed del final\n",
    "    df_embi = df_embi.loc[:, ~df_embi.columns.str.startswith(\"Unnamed\")]\n",
    "\n",
    "    # La primera columna es la fecha (sea cual sea su nombre)\n",
    "    df_embi = df_embi.rename(columns={df_embi.columns[0]: \"fecha\"})\n",
    "\n",
    "    # Parsear fecha\n",
    "    df_embi[\"fecha\"] = pd.to_datetime(df_embi[\"fecha\"], errors=\"coerce\")\n",
    "    df_embi = df_embi.replace(\"N/A\", float(\"nan\"))\n",
    "\n",
    "    # Convertir a numérico\n",
    "    cols_numericas = [c for c in df_embi.columns if c != \"fecha\"]\n",
    "    df_embi[cols_numericas] = df_embi[cols_numericas].apply(pd.to_numeric, errors=\"coerce\")\n",
    "\n",
    "    # Limpiar y ordenar\n",
    "    df_embi = df_embi.dropna(subset=[\"fecha\"]).sort_values(\"fecha\").reset_index(drop=True)\n",
    "\n",
    "    # Series derivadas\n",
    "    df_chile = df_embi[[\"fecha\", \"Chile\"]].dropna()\n",
    "    paises   = [\"Chile\", \"Brasil\", \"Colombia\", \"México\", \"Perú\", \"Argentina\"]\n",
    "    df_latam = df_embi[[\"fecha\"] + paises].copy()\n",
    "\n",
    "    ultimo_valor = df_chile[\"Chile\"].iloc[-1]\n",
    "    ultima_fecha = df_chile[\"fecha\"].iloc[-1].strftime(\"%d/%m/%Y\")\n",
    "\n",
    "except Exception as e:\n",
    "    display(Markdown(f\"**Error al cargar datos:** `{e}`\"))\n",
    "    df_embi      = pd.DataFrame()\n",
    "    df_chile     = pd.DataFrame({\"fecha\": [], \"Chile\": []})\n",
    "    df_latam     = pd.DataFrame()\n",
    "    paises       = []\n",
    "    ultimo_valor = None\n",
    "    ultima_fecha = \"Sin datos\"\n",
    "\n",
    "\n",
    "# --- Tabla: últimos 10 días ---\n",
    "if not df_embi.empty:\n",
    "    paises_tabla = [\"Chile\", \"Brasil\", \"Colombia\", \"México\", \"Perú\", \"Argentina\"]\n",
    "    df_tabla_embi = df_embi[[\"fecha\"] + paises_tabla].dropna(subset=[\"Chile\"]).tail(10).copy()\n",
    "    df_tabla_embi = df_tabla_embi.sort_values(\"fecha\", ascending=False)\n",
    "    df_tabla_embi[\"fecha\"] = df_tabla_embi[\"fecha\"].dt.strftime(\"%d/%m/%Y\")\n",
    "\n",
    "    tabla_md = \"| Fecha | Chile | Brasil | Colombia | México | Perú | Argentina |\\n\"\n",
    "    tabla_md += \"|:---|:---:|:---:|:---:|:---:|:---:|:---:|\\n\"\n",
    "    for _, row in df_tabla_embi.iterrows():\n",
    "        def fmt(v):\n",
    "            return f\"{v:.2f}%\" if pd.notna(v) else \"—\"\n",
    "        tabla_md += (\n",
    "            f\"| {row['fecha']} \"\n",
    "            f\"| {fmt(row['Chile'])} \"\n",
    "            f\"| {fmt(row['Brasil'])} \"\n",
    "            f\"| {fmt(row['Colombia'])} \"\n",
    "            f\"| {fmt(row['México'])} \"\n",
    "            f\"| {fmt(row['Perú'])} \"\n",
    "            f\"| {fmt(row['Argentina'])} |\\n\"\n",
    "        )\n",
    "\n",
    "    display(Markdown(\"### Últimos Datos por País\"))\n",
    "    display(Markdown(tabla_md))"
   ]
