    "#| echo: false\n",
    "\n",
    "#| echo: false\n",
    "\n",
    "# --- Gráfico 2: Comparación LATAM (últimos 5 años) ---\n",
    "if not df_latam.empty:\n",
    "    # Todos los países disponibles (sin fecha y sin columnas extra)\n",
    "    paises_todos = [c for c in df_embi.columns if c != \"fecha\"]\n",
    "    \n",
    "    fecha_corte = df_embi[\"fecha\"].max() - pd.DateOffset(years=5)\n",
    "    df_reciente = df_embi[df_embi[\"fecha\"] >= fecha_corte].copy()\n",
    "\n",
    "    # Paleta de colores automática para todos los países\n",
    "    import plotly.express as px\n",
    "    colores_lista = px.colors.qualitative.Safe\n",
    "    \n",
    "    fig2 = go.Figure()\n",
    "\n",
    "    for i, pais in enumerate(paises_todos):\n",
    "        if pais in df_reciente.columns:\n",
    "            serie = df_reciente[[\"fecha\", pais]].dropna()\n",
    "            if not serie.empty:\n",
    "                fig2.add_trace(\n",
    "                    go.Scatter(\n",
    "                        x=serie[\"fecha\"],\n",
    "                        y=serie[pais],\n",
    "                        mode=\"lines\",\n",
    "                        name=pais,\n",
    "                        line=dict(color=colores_lista[i % len(colores_lista)], width=1.5),\n",
    "                        hovertemplate=f\"<b>%{{x|%d %b %Y}}</b><br>{pais}: %{{y:.2f}}%<extra></extra>\",\n",
    "                    )\n",
    "                )\n",
    "\n",
    "    # Botones de rango temporal\n",
    "    botones_rango = [\n",
    "        dict(count=6,  label=\"6M\",  step=\"month\", stepmode=\"backward\"),\n",
    "        dict(count=1,  label=\"1A\",  step=\"year\",  stepmode=\"backward\"),\n",
    "        dict(count=3,  label=\"3A\",  step=\"year\",  stepmode=\"backward\"),\n",
    "        dict(count=5,  label=\"5A\",  step=\"year\",  stepmode=\"backward\"),\n",
    "        dict(step=\"all\", label=\"Todo\"),\n",
    "    ]\n",
    "\n",
    "    fig2.update_layout(\n",
    "        title=dict(\n",
    "            text=\"Comparación EMBI — Todos los Países\",\n",
    "            x=0.5,\n",
    "            xanchor=\"center\",\n",
    "            font=dict(size=18)\n",
    "        ),\n",
    "        template=\"plotly_white\",\n",
    "        font_family=\"Inter\",\n",
    "        height=500,\n",
    "        autosize=True,\n",
    "        hovermode=\"x unified\",\n",
    "        legend=dict(\n",
    "            orientation=\"h\",\n",
    "            yanchor=\"bottom\",\n",
    "            y=1.08,\n",
    "            xanchor=\"center\",\n",
    "            x=0.5\n",
    "        ),\n",
    "        yaxis=dict(\n",
    "            title=\"Spread (%)\",\n",
    "            tickformat=\".2f\",\n",
    "            gridcolor=\"rgba(0,0,0,0.08)\",\n",
    "            zeroline=False,\n",
    "            rangemode=\"tozero\"\n",
    "        ),\n",
    "        xaxis=dict(\n",
    "            tickformat=\"%b %Y\",\n",
    "            showgrid=False,\n",
    "            rangeselector=dict(\n",
    "                buttons=botones_rango,\n",
    "                bgcolor=\"rgba(0,0,0,0.05)\",\n",
    "                activecolor=\"#2980b9\",\n",
    "                x=0,\n",
    "                y=1.02\n",
    "            ),\n",
    "            rangeslider=dict(visible=False)\n",
    "        ),\n",
    "        margin=dict(l=70, r=40, t=130, b=50)\n",
    "    )\n",
    "\n",
    "    fig2.show(config={\"displayModeBar\": True})  # botones activados"
   ]
