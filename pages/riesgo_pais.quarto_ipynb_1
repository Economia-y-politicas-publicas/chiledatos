    "#| echo: false\n",
    "\n",
    "# --- Gráfico 3: Último valor por país (barras horizontales) ---\n",
    "if not df_latam.empty:\n",
    "    # Definir colores aquí para no depender del bloque anterior\n",
    "    colores = {\n",
    "        \"Chile\":     \"#c0392b\",\n",
    "        \"Brasil\":    \"#2980b9\",\n",
    "        \"Colombia\":  \"#27ae60\",\n",
    "        \"México\":    \"#e67e22\",\n",
    "        \"Perú\":      \"#8e44ad\",\n",
    "        \"Argentina\": \"#2c3e50\",\n",
    "    }\n",
    "\n",
    "    ultimos = {}\n",
    "    for pais in paises:\n",
    "        if pais in df_latam.columns:\n",
    "            serie = df_latam[[\"fecha\", pais]].dropna()\n",
    "            if not serie.empty:\n",
    "                ultimos[pais] = serie[pais].iloc[-1]\n",
    "\n",
    "    df_bar = pd.DataFrame(\n",
    "        list(ultimos.items()), columns=[\"pais\", \"embi\"]\n",
    "    ).sort_values(\"embi\")\n",
    "\n",
    "    colores_bar = [colores.get(p, \"#888\") for p in df_bar[\"pais\"]]\n",
    "\n",
    "    fig3 = go.Figure()\n",
    "    fig3.add_trace(\n",
    "        go.Bar(\n",
    "            x=df_bar[\"embi\"],\n",
    "            y=df_bar[\"pais\"],\n",
    "            orientation=\"h\",\n",
    "            marker_color=colores_bar,\n",
    "            hovertemplate=\"<b>%{y}</b><br>EMBI: %{x:.2f}%<extra></extra>\",\n",
    "            text=df_bar[\"embi\"].apply(lambda v: f\"{v:.2f}%\"),\n",
    "            textposition=\"outside\"\n",
    "        )\n",
    "    )\n",
    "\n",
    "    fig3.update_layout(\n",
    "        title=dict(\n",
    "            text=\"EMBI por País — Último Dato Disponible\",\n",
    "            x=0.5,\n",
    "            xanchor=\"center\",\n",
    "            font=dict(size=18)\n",
    "        ),\n",
    "        template=\"plotly_white\",\n",
    "        font_family=\"Inter\",\n",
    "        height=380,\n",
    "        autosize=True,\n",
    "        xaxis=dict(\n",
    "            title=\"Spread (%)\",\n",
    "            tickformat=\".2f\",\n",
    "            gridcolor=\"rgba(0,0,0,0.08)\",\n",
    "            zeroline=False\n",
    "        ),\n",
    "        yaxis=dict(showgrid=False),\n",
    "        margin=dict(l=90, r=80, t=80, b=50)\n",
    "    )\n",
    "\n",
    "    fig3.show(config={\"displayModeBar\": False})"
