        "## 2. Desempleo por sexo"
      ],
      "id": "c2740b5d"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| fig-cap: \"Tasa de desempleo por sexo (%)\"\n",
        "\n",
        "fig, ax = plt.subplots(figsize=(10, 4))\n",
        "ax.plot(dt[\"fecha\"], dt[\"total\"],  color=\"#f39c12\", linewidth=2, label=\"Total\")\n",
        "ax.plot(dt[\"fecha\"], dt[\"hombre\"], color=\"#2980b9\", linewidth=2, label=\"Hombre\")\n",
        "ax.plot(dt[\"fecha\"], dt[\"mujer\"],  color=\"#e74c3c\", linewidth=2, label=\"Mujer\")\n",
        "ax.set_title(\"Tasa de desempleo por sexo (%)\", fontsize=14, fontweight=\"bold\", pad=12)\n",
        "ax.set_xlabel(\"Año\")\n",
        "ax.set_ylabel(\"Tasa de desempleo (%)\")\n",
        "ax.yaxis.set_major_formatter(ticker.FormatStrFormatter(\"%.1f\"))\n",
        "ax.xaxis.set_major_locator(ticker.MaxNLocator(10))\n",
        "ax.legend(loc=\"upper right\", frameon=False)\n",
        "fig.autofmt_xdate(rotation=0, ha=\"center\")\n",
        "fig.text(0, -0.05, AUTOR, fontsize=9, color=\"gray\", transform=ax.transAxes)\n",
        "fig.text(0, -0.08, AUTOR, fontsize=9, color=\"gray\", transform=ax.transAxes)\n",
        "fig.text(0, -0.14, \"Nota: La tasa de desempleo se mide trimestralmente mediante la ENE.\", \n",
        "         fontsize=9, color=\"#aaaaaa\", transform=ax.transAxes, style=\"italic\")\n",
        "plt.tight_layout()\n",
        "plt.show()"
      ],
