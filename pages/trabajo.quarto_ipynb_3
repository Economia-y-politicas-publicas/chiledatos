        "## 3. Brecha de desempleo mujer − hombre"
      ],
      "id": "40f4d614"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| fig-cap: \"Brecha de desempleo mujer − hombre (puntos porcentuales)\"\n",
        "\n",
        "fig, ax = plt.subplots(figsize=(10, 4))\n",
        "ax.fill_between(dt[\"fecha\"], dt[\"brecha\"], color=\"#8e44ad\", alpha=0.4)\n",
        "ax.plot(dt[\"fecha\"], dt[\"brecha\"], color=\"#8e44ad\", linewidth=1.5)\n",
        "ax.axhline(0, color=\"gray\", linestyle=\"--\", linewidth=0.8)\n",
        "ax.set_title(\"Brecha de desempleo mujer − hombre (pp)\", fontsize=14, fontweight=\"bold\", pad=12)\n",
        "ax.set_xlabel(\"Año\")\n",
        "ax.set_ylabel(\"Puntos porcentuales\")\n",
        "ax.yaxis.set_major_formatter(ticker.FormatStrFormatter(\"%.1f\"))\n",
        "ax.xaxis.set_major_locator(ticker.MaxNLocator(10))\n",
        "fig.autofmt_xdate(rotation=0, ha=\"center\")\n",
        "fig.text(0, -0.05, AUTOR, fontsize=9, color=\"gray\", transform=ax.transAxes)\n",
        "fig.text(0, -0.08, AUTOR, fontsize=9, color=\"gray\", transform=ax.transAxes)\n",
        "fig.text(0, -0.14, \"Nota: La tasa de desempleo se mide trimestralmente mediante la ENE.\", \n",
        "         fontsize=9, color=\"#aaaaaa\", transform=ax.transAxes, style=\"italic\")\n",
        "plt.tight_layout()\n",
        "plt.show()"
