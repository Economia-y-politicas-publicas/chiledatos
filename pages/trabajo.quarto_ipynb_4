    "# Identificar columnas de regiones\n",
    "columnas_excluir = [\"periodo\", \"año\", \"mes\", \"total\", \"hombre\", \"mujer\", \"fecha\", \"brecha\"]\n",
    "columnas_regiones = [col for col in dt.columns if col not in columnas_excluir]\n",
    "\n",
    "# Asegurar que sean numéricas\n",
    "for col in columnas_regiones:\n",
    "    dt[col] = pd.to_numeric(\n",
    "        dt[col].astype(str).str.replace(\",\", \".\").str.strip(),\n",
    "        errors=\"coerce\"\n",
    "    )\n",
    "\n",
    "# Paleta de colores de alto contraste\n",
    "colores = [\n",
    "    \"#e74c3c\",\"#2980b9\",\"#27ae60\",\"#f39c12\",\"#8e44ad\",\n",
    "    \"#16a085\",\"#d35400\",\"#2c3e50\",\"#c0392b\",\"#1abc9c\",\n",
    "    \"#e67e22\",\"#3498db\",\"#9b59b6\",\"#2ecc71\",\"#e74c3c\",\"#f1c40f\",\n",
    "]\n",
    "\n",
    "fig = go.Figure()\n",
    "\n",
    "for i, col in enumerate(columnas_regiones):\n",
    "    fig.add_trace(go.Scatter(\n",
    "        x=dt[\"fecha\"],\n",
    "        y=dt[col],\n",
    "        name=col,\n",
    "        visible=True if col == \"Metropolitana\" else \"legendonly\",\n",
    "        line=dict(color=colores[i % len(colores)], width=3),\n",
    "        hovertemplate=f\"<b>{col}</b><br>%{{x|%b %Y}}<br>%{{y:.1f}}%<extra></extra>\",\n",
    "    ))\n",
    "\n",
    "fig.update_layout(\n",
    "    title=dict(text=\"Tasa de desempleo por región (%)\", font=dict(size=16)),\n",
    "    yaxis_title=\"Tasa de desempleo (%)\",\n",
    "    xaxis=eje_x,\n",
    "    template=\"plotly_white\",\n",
    "    font_family=\"Inter\",\n",
    "    yaxis=dict(tickformat=\".1f\"),\n",
    "    margin=dict(b=160, t=80),\n",
    "    height=520,\n",
    "    legend=dict(\n",
    "        orientation=\"v\",\n",
    "        x=1.02,\n",
    "        y=1,\n",
    "        xanchor=\"left\",\n",
    "        title=\"Regiones<br><i style='font-size:10px'>clic para mostrar/ocultar</i>\",\n",
    "        bgcolor=\"rgba(255,255,255,0.9)\",\n",
    "        bordercolor=\"lightgray\",\n",
    "        borderwidth=1,\n",
    "    ),\n",
    "    xaxis_rangeslider=dict(\n",
    "    visible=True,\n",
